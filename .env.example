# ── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway / Neon / Supabase provide this)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the API server listens on (Railway sets this automatically)
PORT=8080

# Your public app URL — used for Stripe webhooks, Twilio callbacks, billing redirects
# Example: https://your-app.railway.app  or  https://yourdomain.com
APP_URL=https://your-app.railway.app

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Get from: https://dashboard.stripe.com/webhooks  (after creating webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI: Groq (lead generation + email drafting, via Vercel AI SDK) ────────────
# Free key from: https://console.groq.com/keys
GROQ_API_KEY=
# Optional model override (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Twilio (SMS outreach) ─────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ── Resend (email delivery) ───────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
