modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 9091
externalPort = 4200

[[ports]]
localPort = 24006
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
TWILIO_ACCOUNT_SID = "ACc307d0488f0ca77a762b1751350bf24f"
TWILIO_AUTH_TOKEN = "0f5336ba960164ca7e45bc2bc8a8bfd1"
TWILIO_FROM_NUMBER = "+18554870061"
